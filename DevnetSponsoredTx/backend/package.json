{
  "name": "sponsored-transactions-backend",
  "version": "1.0.0",
  "packageManager": "yarn@4.12.0",
  "description": "NestJS backend for Concordium Sponsored Transactions Demo",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "nodemon --watch src --exec \"tsc && node dist/main.js\"",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@concordium/web-sdk": "12.0.0",
    "@grpc/grpc-js": "1.14.3",
    "@nestjs/common": "10.4.20",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "10.4.20",
    "@nestjs/platform-express": "10.4.20",
    "@protobuf-ts/grpc-transport": "2.11.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "nodemon": "3.1.11",
    "typescript": "5.9.3"
  },
  "resolutions": {
    "@grpc/grpc-js": "1.14.3"
  }
}
