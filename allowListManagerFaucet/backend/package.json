{
    "name": "allowlist-backend",
    "version": "0.1.1",
    "description": "NestJS backend for Concordium Allow List dApp",
    "author": "",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "packageManager": "yarn@4.12.0",
    "scripts": {
        "build": "tsc",
        "start": "node dist/main.js",
        "start:dev": "nodemon --watch src --exec \"tsc && node dist/main.js\"",
        "start:prod": "node dist/main.js",
        "lint-fix": "yarn lint --fix",
        "lint": "eslint --cache --max-warnings 0 --ext .ts,.tsx"
    },
    "dependencies": {
        "@concordium/web-sdk": "^10.0.1",
        "@grpc/grpc-js": "^1.12.2",
        "@nestjs/common": "^10.4.5",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^10.4.5",
        "@nestjs/platform-express": "^10.4.5",
        "@nestjs/swagger": "^7.4.2",
        "@protobuf-ts/grpc-transport": "^2.9.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "@types/uuid": "^9.0.8",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.2.5",
        "typescript": "^5.7.2"
    }
}
